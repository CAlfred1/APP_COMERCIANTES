# ==========================================
# Angular - .gitignore Profesional
# ==========================================

# Dependencias
/node_modules

# Compilación
/dist
/out-tsc
/tmp
/bazel-out

# Angular
/.angular
/.angular/cache

# Testing
/coverage
testem.log
__screenshots__/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Archivos temporales
*.tmp
*.temp
.sass-cache/
.connect.lock
/libpeerconnection.log

# Dependencias antiguas
/typings

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Historial VS Code
.history/

# Otros IDEs
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.iml
*.sublime-workspace

# Sistema Operativo
.DS_Store
Thumbs.db
desktop.ini